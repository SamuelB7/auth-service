generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String?
  passwordHash      String
  passwordChangedAt DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id                String    @id @default(cuid())
  userId            String
  tokenHash         String    @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OutboxEvent {
  id          String    @id @default(cuid())
  topic       String
  type        String
  payload     Json
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([topic])
  @@index([publishedAt])
  @@map("outbox_events")
}

